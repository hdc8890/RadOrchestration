{
  "name": "rad-orchestration",
  "version": "1.0.0",
  "description": "Interactive CLI installer for the RadOrchestration system",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "node --test --experimental-test-module-mocks \"lib/**/*.test.js\" \"index.test.js\"",
    "prepack": "node scripts/sync-source.js"
  },
  "bin": {
    "radorch": "./index.js"
  },
  "files": [
    "index.js",
    "lib/",
    "src/",
    "scripts/",
    "!**/*.test.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.0",
    "@inquirer/prompts": "^8.3.0",
    "ora": "^9.3.0",
    "figlet": "^1.11.0"
  }
}

